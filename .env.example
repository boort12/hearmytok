# Database — local dev default (matches docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hearmytok

# Spotify API — register a free app at developer.spotify.com
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Anthropic API — required for AI trend analyst (get key at console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Admin API key — protects POST /api/scheduler/run-now (set any secret string)
ADMIN_API_KEY=your_admin_api_key

# Frontend — update to your deployed backend URL for production
NEXT_PUBLIC_API_URL=http://localhost:8000
